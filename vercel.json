{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://arraji-backend-api.onrender.com/api/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/user/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}