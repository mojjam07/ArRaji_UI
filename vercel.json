{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",

  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://arraji-backend-api.onrender.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}